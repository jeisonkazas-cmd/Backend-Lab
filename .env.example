DATABASE_URL=postgresql://user:password@host:5432/lab_fisica

AZURE_CLIENT_ID=your_client_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# Session
SESSION_SECRET=change_this_secret_to_something_random_and_secure

# Server
PORT=3000
NODE_ENV=production

# CORS
CORS_ORIGIN=https://your-frontend.vercel.app

# Supabase Auth (para validar access_token del frontend)
# URL del proyecto (ej: https://xxxx.supabase.co)
SUPABASE_URL=
# (Opcional) Solo si tu proyecto usa valores distintos
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Logging
LOG_LEVEL=info

